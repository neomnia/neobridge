{
  "name": "neobridge",
  "version": "1.3.1",
  "private": true,
  "scripts": {
    "build": "bash scripts/vercel-build.sh",
    "build:local": "next build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:ensure": "tsx scripts/db-ensure-columns.ts",
    "db:verify": "tsx scripts/db-verify-schema.ts",
    "db:reset": "tsx scripts/reset-db.ts",
    "db:hard-reset": "tsx scripts/reset-db.ts && pnpm db:migrate && tsx scripts/seed-database.ts",
    "db:seed": "tsx scripts/seed-database.ts",
    "db:seed-base": "tsx scripts/seed-base-data.ts",
    "db:studio": "drizzle-kit studio",
    "dev": "next dev",
    "lint": "eslint .",
    "start": "next start",
    "seed:email-templates": "tsx scripts/seed-email-templates.ts",
    "seed:pages": "tsx scripts/sync-pages.ts",
    "check:email-config": "tsx scripts/check-email-config.ts"
  },
  "pnpm": {
    "overrides": {
      "react-native": "npm:empty-npm-package@1.0.0",
      "@vercel/postgres": "npm:empty-npm-package@1.0.0"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "react-native",
        "@op-engineering/op-sqlite",
        "@libsql/client",
        "@libsql/client-wasm",
        "expo-sqlite",
        "gel",
        "better-sqlite3",
        "bun-types",
        "kysely",
        "knex",
        "mysql2",
        "postgres",
        "sql.js",
        "sqlite3",
        "@prisma/client",
        "@tidbcloud/serverless",
        "@planetscale/database",
        "@electric-sql/pglite",
        "@cloudflare/workers-types",
        "@aws-sdk/client-rds-data",
        "@xata.io/client",
        "@types/sql.js",
        "@types/better-sqlite3"
      ],
      "allowedVersions": {
        "react-native>react": "*"
      },
      "allowedDeprecatedVersions": {
        "@vercel/postgres": "*",
        "@esbuild-kit/core-utils": "*",
        "@esbuild-kit/esm-loader": "*",
        "@npmcli/move-file": "*",
        "are-we-there-yet": "*",
        "gauge": "*",
        "glob": "*",
        "inflight": "*",
        "node-domexception": "*",
        "npmlog": "*",
        "rimraf": "*",
        "tar": "*"
      }
    }
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@neondatabase/serverless": "latest",
    "@opentelemetry/api": "latest",
    "@radix-ui/react-accordion": "latest",
    "@radix-ui/react-alert-dialog": "latest",
    "@radix-ui/react-aspect-ratio": "latest",
    "@radix-ui/react-avatar": "latest",
    "@radix-ui/react-checkbox": "latest",
    "@radix-ui/react-collapsible": "latest",
    "@radix-ui/react-context-menu": "latest",
    "@radix-ui/react-dialog": "latest",
    "@radix-ui/react-dropdown-menu": "latest",
    "@radix-ui/react-hover-card": "latest",
    "@radix-ui/react-label": "latest",
    "@radix-ui/react-menubar": "latest",
    "@radix-ui/react-navigation-menu": "latest",
    "@radix-ui/react-popover": "latest",
    "@radix-ui/react-progress": "latest",
    "@radix-ui/react-radio-group": "latest",
    "@radix-ui/react-scroll-area": "latest",
    "@radix-ui/react-select": "latest",
    "@radix-ui/react-separator": "latest",
    "@radix-ui/react-slider": "latest",
    "@radix-ui/react-slot": "latest",
    "@radix-ui/react-switch": "latest",
    "@radix-ui/react-tabs": "latest",
    "@radix-ui/react-toast": "latest",
    "@radix-ui/react-toggle": "latest",
    "@radix-ui/react-toggle-group": "latest",
    "@radix-ui/react-tooltip": "latest",
    "@stripe/react-stripe-js": "^5.6.0",
    "@stripe/stripe-js": "^8.7.0",
    "@types/react-big-calendar": "^1.16.3",
    "@upstash/redis": "latest",
    "autoprefixer": "^10.4.20",
    "bcryptjs": "latest",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "latest",
    "cookie": "^1.0.2",
    "date-fns": "4.1.0",
    "dotenv": "latest",
    "drizzle-orm": "latest",
    "embla-carousel-react": "latest",
    "geist": "^1.3.1",
    "input-otp": "latest",
    "jose": "latest",
    "jsonwebtoken": "latest",
    "lago-javascript-client": "^1.36.0",
    "lucide-react": "^0.454.0",
    "next": "latest",
    "next-themes": "latest",
    "pg": "^8.16.3",
    "react": "^19",
    "react-big-calendar": "^1.19.4",
    "react-day-picker": "latest",
    "react-dom": "^19",
    "react-easy-crop": "^5.5.6",
    "react-hook-form": "latest",
    "react-resizable-panels": "latest",
    "recharts": "latest",
    "sonner": "latest",
    "stripe": "^20.3.1",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "latest",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22",
    "@types/pg": "^8.15.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.7",
    "postcss": "^8.5",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.6",
    "typescript": "^5.7.2"
  },
  "trustedDependencies": [
    "pg-native"
  ]
}
