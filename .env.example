# ============================================================================
# NeoSaaS - Free Version - Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env file to git!

# ============================================================================
# DATABASE
# ============================================================================
# PostgreSQL connection string (Neon, Supabase, or any PostgreSQL)
# Pour Neon : utiliser l'URL poolée (pgBouncer) pour les requêtes applicatives
DATABASE_URL=postgresql://neondb_owner:PASSWORD@ep-XXXX-pooler.c-2.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Pour Neon : URL directe (sans pooler) pour les migrations Drizzle
# Remplacer "-pooler" par l'endpoint direct dans l'URL ci-dessus
DATABASE_URL_UNPOOLED=postgresql://neondb_owner:PASSWORD@ep-XXXX.c-2.eu-central-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ============================================================================
# AUTHENTICATION
# ============================================================================
# Secret key for JWT tokens (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-secret-key-at-least-32-characters-long

# ============================================================================
# APPLICATION
# ============================================================================
# Public URL of your application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================================
# STRIPE (Optional — managed via Admin > API Management)
# These are fallback env vars; prefer using the Admin UI to store keys.
# ============================================================================
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================================
# EMAIL PROVIDER (Choose one or configure multiple)
# ============================================================================

# RESEND (Recommended for simplicity)
RESEND_API_KEY=re_xxxxxxxxxxxx

# OR SCALEWAY TEM
SCALEWAY_TEM_PROJECT_ID=your-project-id
SCALEWAY_TEM_SECRET_KEY=your-secret-key
SCALEWAY_TEM_API_URL=https://api.tem.scaleway.com

# OR AWS SES
AWS_REGION=eu-west-1
AWS_SES_ACCESS_KEY_ID=your-access-key
AWS_SES_SECRET_ACCESS_KEY=your-secret-key

# ============================================================================
# ZOHO PROJECTS (Optional — for /dashboard/projects-pm)
# ============================================================================
# OAuth credentials from https://api-console.zoho.com
# ZOHO_DOMAIN controls the datacenter: "zoho.com" (global/US, default),
#   "zoho.eu" (EU), "zoho.in" (India), "zoho.com.au" (AU)
ZOHO_DOMAIN=zoho.com
# Portal slug — visible in your Zoho Projects URL:
#   https://projects.zoho.com/portal/<ZOHO_PORTAL_ID>
ZOHO_PORTAL_ID=neomniadotnet
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
ZOHO_REFRESH_TOKEN=your-zoho-refresh-token

# ============================================================================
# OPTIONAL FEATURES
# ============================================================================

# Contact form destination email (for support requests)
CONTACT_EMAIL=support@yourdomain.com

# Admin notification email
ADMIN_EMAIL=admin@yourdomain.com
